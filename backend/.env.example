# RAG Configuration (Retrieval Augmented Generation)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Number of document chunks to retrieve for each query (higher = more context)
RAG_TOP_K_CHUNKS_USED=5

# QA Configuration (Question Answering)
# Settings for the cloud-based QA engine. Users can choose between local or cloud models in the frontend.
# Cloud model: OpenAI (configured below)
# Local model: DistilBERT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# NER Configuration (Named Entity Recognition)
SPACY_MODEL=en_core_web_sm
